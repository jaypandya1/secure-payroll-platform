# Copy this file to terraform.tfvars and replace placeholders with real values.

aws_region = "eu-west-2"
project_name = "oceans-payroll"
environment = "dev"
vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = ["10.0.0.0/25", "10.0.0.128/25"]
private_subnet_cidrs_companies = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs_bureaus = ["10.0.3.0/24", "10.0.4.0/24"]
private_subnet_cidrs_employees = ["10.0.5.0/24", "10.0.6.0/24"]
availability_zones = ["eu-west-2a", "eu-west-2b"]

db_name = "payroll_db"
db_username = "payroll_admin"

companies_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:companies-secret"
bureaus_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:bureaus-secret"
employees_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:employees-secret"

s3_bucket_name = "your-unique-oceans-payroll-bucket-name"
