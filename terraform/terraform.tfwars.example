# ==============================================================================
# Copy to terraform.tfvars and fill in real values — never commit terraform.tfvars to git
# ==============================================================================

# AWS Region (e.g., eu-west-2 for UK)
aws_region = "eu-west-2"

# Project name (used for tagging)
project_name = "oceans-payroll"

# Environment (must be 'dev' or 'prod')
environment = "dev"

# The globally unique S3 bucket name
s3_bucket_name = "your-unique-oceans-payroll-bucket-name"

# Provide the ARNs for the AWS Secrets Manager secrets holding the DB credentials.
# You must create these in the AWS Console or via AWS CLI before running apply.
companies_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:companies-secret"
bureaus_secret_arn   = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:bureaus-secret"
employees_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:employees-secret"


/* ==============================================================================
.gitignore additions
==============================================================================

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore variables files containing sensitive data
terraform.tfvars
*.auto.tfvars
*/